{
  "name": "md-note-graph",
  "version": "1.0.0",
  "description": "Markdown 笔记关系图管理工具",
  "main": "electron/main.js",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "dev:go": "cd backend && go run .",
    "dev": "concurrently -k \"npm:dev:go\" \"npm:dev:vite\" \"npm:dev:electron\"",
    "build:go": "cd backend && go build -o ../bin/md-server .",
    "build:vite": "vite build",
    "build": "npm run build:go && npm run build:vite && electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "d3": "^7.8.5",
    "vue": "^3.4.0",
    "wait-on": "^7.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.mdnotegraph.app",
    "productName": "MD Note Graph",
    "files": [
      "electron/**/*",
      "dist/**/*",
      "bin/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}
